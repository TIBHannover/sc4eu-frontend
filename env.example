## This is an example env file that holds the environment variables for the deployed services

# you have to specify those correctly !!!

#>> This is the backend for data
REACT_APP_FLASK_BACKEND_URL="http://localhost:5000/"


#>> this is the backend for the express app which does the authentication using OAuth2
REACT_APP_EXPRESS_BACKEND_URL="http://localhost:9000/"

# OAUTH USING GITHUB
#############################################################################################
## WE need here additional ENV vars for storing the github access tokens
# THIS YOU OBTAIN BY REGISTERING A NEW APPLICATION IN GITHUB
# FOR MORE INFO SEE
#https://docs.github.com/en/free-pro-team@latest/developers/apps/authorizing-oauth-apps


GITHUB_CLIENT_ID = '<ID VALUE>'
GITHUB_CLIENT_SECRET = '<SECRET VALUE>'


#############################################################################################