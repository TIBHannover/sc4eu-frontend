## WE need here additional ENV vars for storing the github access tokens

GITHUB_CLIENT_ID='your_github_client_id'
GITHUB_CLIENT_SECRET='your_github_client_secret'

GITHUB_CLIENT_ID_FOR_LOGIN='your_github_login_client_id'
GITHUB_CLIENT_SECRET_FOR_LOGIN='your_github_login_client_secret'

GITLAB_CLIENT_ID='your_gitlab_client_id'
GITLAB_CLIENT_SECRET='your_gitlab_client_secret'

GOOGLE_CLIENT_ID_FOR_LOGIN='your_google_client_id'
GOOGLE_CLIENT_SECRET_FOR_LOGIN='your_google_client_secret'

SAP_AUTHORIZATION_URL_FOR_LOGIN='your_sap_authorization_url'
SAP_TOKEN_URL_FOR_LOGIN='your_sap_token_url'
SAP_USER_INFO_URL='your_sap_user_info_url'
SAP_CLIENT_ID_FOR_LOGIN='your_sap_client_id'
SAP_CLIENT_SECRET_FOR_LOGIN='your_sap_client_secret'

JWT_SECRET='your_jwt_secret_key'

# note the application port has to be consistent with the port we use in GitHub for the callback url
APPLICATION_PORT='9000'
APPLICATION_URL='http://localhost'
BACKEND_SERVER_URL='http://localhost:5000'
PROCESSING_SERVER_URL='http://localhost:12463'
CALLBACK_URL='https://service.tib.eu'
REDIRECT_URL='https://service.tib.eu'

MAIL_HOST='your.mail.host'
MAIL_PORT=25
MAIL_SECURE=false
MAIL_USER_NAME='your.email@domain.com'
