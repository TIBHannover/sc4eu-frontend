{
  "name": "sc3-demo-application",
  "version": "0.0.1",
  "private": true,
  "homepage": "./ocp",
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@fortawesome/fontawesome-svg-core": "^6.5.2",
    "@fortawesome/free-brands-svg-icons": "^5.15.4",
    "@fortawesome/free-regular-svg-icons": "^5.15.4",
    "@fortawesome/free-solid-svg-icons": "^6.5.1",
    "@fortawesome/react-fontawesome": "^0.1.19",
    "@material-ui/core": "^5.0.0-beta.5",
    "@material-ui/lab": "^5.0.0-alpha.44",
    "@material-ui/styles": "^4.11.5",
    "@mui/icons-material": "^5.15.15",
    "@mui/material": "^5.15.15",
    "@mui/x-date-pickers": "^6.16.0",
    "@octokit/rest": "^19.0.13",
    "@tanstack/react-query": "^4.36.1",
    "@tanstack/react-query-devtools": "^4.36.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^9.5.0",
    "@testing-library/user-event": "^14.5.2",
    "@tippyjs/react": "^4.2.6",
    "axios": "^1.6.7",
    "babel-eslint": "^10.1.0",
    "bootstrap": "^4.6.2",
    "buffer": "^6.0.3",
    "classnames": "^2.5.1",
    "connected-react-router": "^6.9.3",
    "d3": "^3.5.6",
    "detect-browser": "^4.7.0",
    "dot-prop-immutable": "^2.1.1",
    "fast-text-encoding": "^1.0.6",
    "history": "^4.10.1",
    "html-react-parser": "^0.14.2",
    "html2canvas": "^1.4.1",
    "js-cookie": "^3.0.5",
    "lodash": "^4.17.21",
    "material-react-table": "^2.13.0",
    "n3": "^1.20.4",
    "passport": "^0.7.0",
    "passport-github": "^1.1.0",
    "path": "^0.12.7",
    "path-to-regexp": "^6.2.2",
    "prop-types": "^15.8.1",
    "react": "^17.0.1",
    "react-clamp-lines": "^3.0.3",
    "react-cookie": "^4.1.1",
    "react-custom-scrollbars-2": "^4.5.0",
    "react-dnd": "^10.0.2",
    "react-dnd-html5-backend": "^10.0.2",
    "react-dom": "^17.0.1",
    "react-dotdotdot": "^1.3.1",
    "react-modern-drawer": "^1.2.2",
    "react-piwik": "^1.12.0",
    "react-redux": "^7.2.9",
    "react-router": "^5.3.4",
    "react-router-config": "^5.0.1",
    "react-router-dom": "^5.3.4",
    "react-scripts": "^5.0.1",
    "react-select": "^5.8.0",
    "react-table": "^7.8.0",
    "react-transition-group": "^2.9.0",
    "redux": "^4.2.1",
    "redux-persist": "^6.0.0",
    "redux-thunk": "^2.4.2",
    "sass": "^1.32.12",
    "source-map-explorer": "^2.5.3",
    "strict-mode": "^1.1.5",
    "styled-components": "^5.3.11",
    "typed.js": "^2.1.0",
    "util": "^0.12.5",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "@beam-australia/react-env": "^2.1.2",
    "depcheck": "^1.4.7",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^6.4.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-prettier": "^3.4.1",
    "greeting-time": "^1.0.0",
    "named-urls": "^2.0.1",
    "prettier": "^1.18.2",
    "process-env": "^2.0.2",
    "react-gravatar": "^2.6.3",
    "reactstrap": "^8.10.1"
  },
  "scripts": {
    "analyze": "source-map-explorer 'build/static/js/*.js'",
    "start_client": "react-scripts start",
    "start": "npm run build  && (cd server && npm start)",
    "build": "BUILD_PATH='./build/ocp' react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix"
  },
  "auto-changelog": {
    "template": "./keepachangelog.hbs",
    "unreleased": false,
    "commitLimit": 0,
    "tagPattern": ".+",
    "tagPrefix": "V"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "npm run --silent lint:fix",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "babelMacros": {
    "styledComponents": {
      "pure": true
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "prettier"
    ],
    "plugins": [
      "prettier",
      "import"
    ],
    "rules": {
      "prettier/prettier": [
        "error"
      ],
      "import/no-anonymous-default-export": [
        "error",
        {
          "allowArray": false,
          "allowArrowFunction": true,
          "allowAnonymousClass": false,
          "allowAnonymousFunction": false,
          "allowCallExpression": true,
          "allowLiteral": false,
          "allowObject": true
        }
      ],
      "react/jsx-closing-bracket-location": [
        "error"
      ],
      "react/jsx-closing-tag-location": [
        "error"
      ],
      "react/sort-comp": [
        "error"
      ],
      "jsx-quotes": [
        "error"
      ],
      "no-multi-spaces": [
        "error"
      ],
      "react/jsx-tag-spacing": [
        "error"
      ],
      "react/jsx-curly-spacing": [
        "error"
      ],
      "curly": [
        "error"
      ],
      "react/jsx-wrap-multilines": [
        "error"
      ],
      "react/self-closing-comp": [
        "error"
      ],
      "react/prop-types": [
        "error"
      ],
      "no-var": [
        "error"
      ],
      "no-const-assign": [
        "error"
      ],
      "prefer-const": [
        1
      ]
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
